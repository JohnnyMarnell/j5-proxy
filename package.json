{
  "name": "j5-proxy",
  "version": "1.0.2",
  "description": "Proxy utility that can seamlessly pass Cloudfare bot detection and automatically inject cookies",
  "module": "index.ts",
  "main": "dist/api.js",
  "type": "module",
  "bin": {
    "j5-proxy": "./bin/j5-proxy.js"
  },
  "exports": {
    ".": {
      "bun": "./api.ts",
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    }
  },
  "files": [
    "dist/",
    "bin/",
    "index.ts",
    "lib.ts",
    "core.ts",
    "api.ts",
    "cookies.py",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "playwright",
    "proxy",
    "headless",
    "chrome",
    "stealth",
    "scraping",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JohnnyMarnell/j5-proxy.git"
  },
  "homepage": "https://github.com/JohnnyMarnell/j5-proxy#readme",
  "bugs": "https://github.com/JohnnyMarnell/j5-proxy/issues",
  "license": "MIT",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "bun --hot index.ts",
    "bot": "bash ./bin/bot-test.sh",
    "typecheck": "tsc --noEmit",
    "build": "bun build --target=node --outdir=dist index.ts api.ts",
    "build:types": "tsc --project tsconfig.build.json",
    "build:all": "bun run build && bun run build:types",
    "build:bin:mac-arm64": "bun build --compile --target=bun-darwin-arm64  --outfile dist/binaries/j5-proxy-mac-arm64   index.ts",
    "build:bin:mac-x64": "bun build --compile --target=bun-darwin-x64    --outfile dist/binaries/j5-proxy-mac-x64     index.ts",
    "build:bin:linux-x64": "bun build --compile --target=bun-linux-x64     --outfile dist/binaries/j5-proxy-linux-x64   index.ts",
    "build:bin:linux-arm64": "bun build --compile --target=bun-linux-arm64   --outfile dist/binaries/j5-proxy-linux-arm64 index.ts",
    "build:bins": "bun run build:bin:mac-arm64 && bun run build:bin:mac-x64 && bun run build:bin:linux-x64 && bun run build:bin:linux-arm64",
    "postinstall": "playwright install chromium",
    "test": "bun test test/",
    "test:unit": "bun test test/",
    "test:e2e": "bun test ./e2e --timeout 60000",
    "test:all": "bun test test/ ./e2e --timeout 60000",
    "test:v": "VERBOSE=1 bun test test/ ./e2e --timeout 60000",
    "e2e": "bun test ./e2e --timeout 60000"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-notifier": "^8.0.5",
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "apify-client": "^2.22.1",
    "consola": "^3.4.2",
    "hono": "^4.12.3",
    "node-notifier": "^10.0.1",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "yargs": "^18.0.0"
  }
}
